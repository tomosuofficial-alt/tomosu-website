{
  "rewrites": [
    { "source": "/", "destination": "/TOMOSU Corporate Site.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(jpg|jpeg|png|webp|gif|svg|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(css|js|jsx))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
